    "engine": "knitr",
    "markdown": "---\ntitle: \"Regional regressions\"\n---\n\n::: {.cell}\n\n```{.r .cell-code}\nlibrary(dplyr)\nlibrary(readr)\nlibrary(ggplot2)\nlibrary(broom)\nlibrary(DT)\nlibrary(scales)\n\ndf <- read_csv(\n  \"data/bfnee_regression_dataset.csv\",\n  show_col_types = FALSE\n)\n\ndf_model <- df %>%\n  filter(\n    !is.na(continent),\n    !is.na(log_bfnee),\n    !is.na(log_natural_loss),\n    !is.na(log_weight_sum),\n    natural_loss_sum_km2 > 0,\n    bfnee_sum_km2 > 0\n  )\n```\n:::\n\n\n\n\n# Data coverage\n\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\ndf_model %>%\n  distinct(continent, iso3) %>%\n  count(continent, name = \"n_countries\") %>%\n  arrange(continent)\n```\n\n::: {.cell-output-display}\n`````{=html}\n<div data-pagedtable=\"false\">\n  <script data-pagedtable-source type=\"application/json\">\n{\"columns\":[{\"label\":[\"continent\"],\"name\":[1],\"type\":[\"chr\"],\"align\":[\"left\"]},{\"label\":[\"n_countries\"],\"name\":[2],\"type\":[\"int\"],\"align\":[\"right\"]}],\"data\":[{\"1\":\"Africa\",\"2\":\"41\"},{\"1\":\"Asia\",\"2\":\"42\"},{\"1\":\"Europe\",\"2\":\"32\"},{\"1\":\"North America\",\"2\":\"14\"},{\"1\":\"Oceania\",\"2\":\"2\"},{\"1\":\"South America\",\"2\":\"9\"}],\"options\":{\"columns\":{\"min\":{},\"max\":[10]},\"rows\":{\"min\":[10],\"max\":[10]},\"pages\":{}}}\n  </script>\n</div>\n`````\n:::\n:::\n\n::: {.cell}\n\n```{.r .cell-code}\ndf_model %>%\n  count(continent, year) %>%\n  arrange(continent, year)\n```\n\n::: {.cell-output-display}\n`````{=html}\n<div data-pagedtable=\"false\">\n  <script data-pagedtable-source type=\"application/json\">\n{\"columns\":[{\"label\":[\"continent\"],\"name\":[1],\"type\":[\"chr\"],\"align\":[\"left\"]},{\"label\":[\"year\"],\"name\":[2],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"n\"],\"name\":[3],\"type\":[\"int\"],\"align\":[\"right\"]}],\"data\":[{\"1\":\"Africa\",\"2\":\"2000\",\"3\":\"41\"},{\"1\":\"Africa\",\"2\":\"2005\",\"3\":\"41\"},{\"1\":\"Africa\",\"2\":\"2010\",\"3\":\"41\"},{\"1\":\"Africa\",\"2\":\"2015\",\"3\":\"41\"},{\"1\":\"Asia\",\"2\":\"2000\",\"3\":\"42\"},{\"1\":\"Asia\",\"2\":\"2005\",\"3\":\"42\"},{\"1\":\"Asia\",\"2\":\"2010\",\"3\":\"41\"},{\"1\":\"Asia\",\"2\":\"2015\",\"3\":\"41\"},{\"1\":\"Europe\",\"2\":\"2000\",\"3\":\"32\"},{\"1\":\"Europe\",\"2\":\"2005\",\"3\":\"32\"},{\"1\":\"Europe\",\"2\":\"2010\",\"3\":\"32\"},{\"1\":\"Europe\",\"2\":\"2015\",\"3\":\"32\"},{\"1\":\"North America\",\"2\":\"2000\",\"3\":\"14\"},{\"1\":\"North America\",\"2\":\"2005\",\"3\":\"14\"},{\"1\":\"North America\",\"2\":\"2010\",\"3\":\"14\"},{\"1\":\"North America\",\"2\":\"2015\",\"3\":\"14\"},{\"1\":\"Oceania\",\"2\":\"2000\",\"3\":\"2\"},{\"1\":\"Oceania\",\"2\":\"2005\",\"3\":\"2\"},{\"1\":\"Oceania\",\"2\":\"2010\",\"3\":\"2\"},{\"1\":\"Oceania\",\"2\":\"2015\",\"3\":\"2\"},{\"1\":\"South America\",\"2\":\"2000\",\"3\":\"9\"},{\"1\":\"South America\",\"2\":\"2005\",\"3\":\"9\"},{\"1\":\"South America\",\"2\":\"2010\",\"3\":\"9\"},{\"1\":\"South America\",\"2\":\"2015\",\"3\":\"9\"}],\"options\":{\"columns\":{\"min\":{},\"max\":[10]},\"rows\":{\"min\":[10],\"max\":[10]},\"pages\":{}}}\n  </script>\n</div>\n`````\n:::\n:::\n\n\n\n\n# Model specification\n\nThe first regional consistency model is:\n\n```text\nlog(BF-NEE + 1) ~ log(natural ecosystem loss + 1) + log(weight sum + 1)\n```\n\nwhere `weight_sum` represents the aggregated commodity-consumption and production-attribution component.\n\n# BF-NEE and natural ecosystem loss\n\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\nggplot(\n  df_model,\n  aes(\n    x = natural_loss_sum_km2,\n    y = bfnee_sum_km2\n  )\n) +\n  geom_point(alpha = 0.6) +\n  geom_smooth(method = \"lm\", se = FALSE) +\n  facet_wrap(~ continent, scales = \"free\") +\n  scale_x_continuous(labels = comma) +\n  scale_y_continuous(labels = comma) +\n  labs(\n    title = \"BF-NEE vs natural ecosystem loss\",\n    subtitle = \"Validated countries only\",\n    x = \"Natural ecosystem loss (km²)\",\n    y = \"BF-NEE (km²)\"\n  ) +\n  theme_minimal()\n```\n\n::: {.cell-output-display}\n![](06_regional_regressions_files/figure-html/unnamed-chunk-4-1.svg){width=672}\n:::\n:::\n\n\n\n\n# Log-log relationship\n\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\nggplot(\n  df_model,\n  aes(\n    x = log_natural_loss,\n    y = log_bfnee\n  )\n) +\n  geom_point(alpha = 0.6) +\n  geom_smooth(method = \"lm\", se = FALSE) +\n  facet_wrap(~ continent, scales = \"free\") +\n  labs(\n    title = \"Log-log relationship between BF-NEE and natural ecosystem loss\",\n    subtitle = \"Validated countries only\",\n    x = \"log(natural ecosystem loss + 1)\",\n    y = \"log(BF-NEE + 1)\"\n  ) +\n  theme_minimal()\n```\n\n::: {.cell-output-display}\n![](06_regional_regressions_files/figure-html/unnamed-chunk-5-1.svg){width=672}\n:::\n:::\n\n\n\n\n# Regional regression models\n\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\nfit_region <- function(x) {\n  lm(\n    log_bfnee ~ log_natural_loss + log_weight_sum,\n    data = x\n  )\n}\n\nregional_models <- df_model %>%\n  group_by(continent) %>%\n  group_modify(~ {\n    model <- fit_region(.x)\n    \n    tidy_model <- tidy(model)\n    glance_model <- glance(model)\n    \n    tidy_model %>%\n      mutate(\n        r_squared = glance_model$r.squared,\n        adj_r_squared = glance_model$adj.r.squared,\n        n_obs = glance_model$nobs\n      )\n  }) %>%\n  ungroup()\n\nregional_models\n```\n\n::: {.cell-output-display}\n`````{=html}\n<div data-pagedtable=\"false\">\n  <script data-pagedtable-source type=\"application/json\">\n{\"columns\":[{\"label\":[\"continent\"],\"name\":[1],\"type\":[\"chr\"],\"align\":[\"left\"]},{\"label\":[\"term\"],\"name\":[2],\"type\":[\"chr\"],\"align\":[\"left\"]},{\"label\":[\"estimate\"],\"name\":[3],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"std.error\"],\"name\":[4],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"statistic\"],\"name\":[5],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"p.value\"],\"name\":[6],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"r_squared\"],\"name\":[7],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"adj_r_squared\"],\"name\":[8],\"type\":[\"dbl\"],\"align\":[\"right\"]},{\"label\":[\"n_obs\"],\"name\":[9],\"type\":[\"int\"],\"align\":[\"right\"]}],\"data\":[{\"1\":\"Africa\",\"2\":\"(Intercept)\",\"3\":\"-5.8040932\",\"4\":\"0.38312137\",\"5\":\"-15.149490\",\"6\":\"8.605561e-33\",\"7\":\"0.8130765\",\"8\":\"0.8107545\",\"9\":\"164\"},{\"1\":\"Africa\",\"2\":\"log_natural_loss\",\"3\":\"0.9510962\",\"4\":\"0.03948735\",\"5\":\"24.086097\",\"6\":\"2.970362e-55\",\"7\":\"0.8130765\",\"8\":\"0.8107545\",\"9\":\"164\"},{\"1\":\"Africa\",\"2\":\"log_weight_sum\",\"3\":\"107.4527874\",\"4\":\"6.91805864\",\"5\":\"15.532217\",\"6\":\"7.846539e-34\",\"7\":\"0.8130765\",\"8\":\"0.8107545\",\"9\":\"164\"},{\"1\":\"Asia\",\"2\":\"(Intercept)\",\"3\":\"-4.3243909\",\"4\":\"0.23148519\",\"5\":\"-18.681070\",\"6\":\"2.323763e-42\",\"7\":\"0.8700959\",\"8\":\"0.8685020\",\"9\":\"166\"},{\"1\":\"Asia\",\"2\":\"log_natural_loss\",\"3\":\"0.8509280\",\"4\":\"0.02627500\",\"5\":\"32.385466\",\"6\":\"6.595839e-73\",\"7\":\"0.8700959\",\"8\":\"0.8685020\",\"9\":\"166\"},{\"1\":\"Asia\",\"2\":\"log_weight_sum\",\"3\":\"52.9996331\",\"4\":\"4.05489898\",\"5\":\"13.070519\",\"6\":\"3.658094e-27\",\"7\":\"0.8700959\",\"8\":\"0.8685020\",\"9\":\"166\"},{\"1\":\"Europe\",\"2\":\"(Intercept)\",\"3\":\"-2.3315124\",\"4\":\"0.27242633\",\"5\":\"-8.558323\",\"6\":\"3.506916e-14\",\"7\":\"0.8555396\",\"8\":\"0.8532283\",\"9\":\"128\"},{\"1\":\"Europe\",\"2\":\"log_natural_loss\",\"3\":\"0.8147599\",\"4\":\"0.03407275\",\"5\":\"23.912359\",\"6\":\"1.808775e-48\",\"7\":\"0.8555396\",\"8\":\"0.8532283\",\"9\":\"128\"},{\"1\":\"Europe\",\"2\":\"log_weight_sum\",\"3\":\"9.4842158\",\"4\":\"0.58727671\",\"5\":\"16.149484\",\"6\":\"2.212304e-32\",\"7\":\"0.8555396\",\"8\":\"0.8532283\",\"9\":\"128\"},{\"1\":\"North America\",\"2\":\"(Intercept)\",\"3\":\"-4.5827183\",\"4\":\"0.26228940\",\"5\":\"-17.471992\",\"6\":\"1.196393e-23\",\"7\":\"0.9545303\",\"8\":\"0.9528145\",\"9\":\"56\"},{\"1\":\"North America\",\"2\":\"log_natural_loss\",\"3\":\"0.9123274\",\"4\":\"0.02931592\",\"5\":\"31.120539\",\"6\":\"9.943092e-36\",\"7\":\"0.9545303\",\"8\":\"0.9528145\",\"9\":\"56\"},{\"1\":\"North America\",\"2\":\"log_weight_sum\",\"3\":\"56.5823178\",\"4\":\"3.76501791\",\"5\":\"15.028433\",\"6\":\"9.386982e-21\",\"7\":\"0.9545303\",\"8\":\"0.9528145\",\"9\":\"56\"},{\"1\":\"Oceania\",\"2\":\"(Intercept)\",\"3\":\"-5.8040016\",\"4\":\"0.47055616\",\"5\":\"-12.334344\",\"6\":\"6.203181e-05\",\"7\":\"0.9924465\",\"8\":\"0.9894250\",\"9\":\"8\"},{\"1\":\"Oceania\",\"2\":\"log_natural_loss\",\"3\":\"1.0355559\",\"4\":\"0.04234663\",\"5\":\"24.454269\",\"6\":\"2.131968e-06\",\"7\":\"0.9924465\",\"8\":\"0.9894250\",\"9\":\"8\"},{\"1\":\"Oceania\",\"2\":\"log_weight_sum\",\"3\":\"69.8409709\",\"4\":\"8.34768380\",\"5\":\"8.366509\",\"6\":\"3.993039e-04\",\"7\":\"0.9924465\",\"8\":\"0.9894250\",\"9\":\"8\"},{\"1\":\"South America\",\"2\":\"(Intercept)\",\"3\":\"-6.2048554\",\"4\":\"0.76366129\",\"5\":\"-8.125141\",\"6\":\"2.226461e-09\",\"7\":\"0.9000510\",\"8\":\"0.8939935\",\"9\":\"36\"},{\"1\":\"South America\",\"2\":\"log_natural_loss\",\"3\":\"1.0829790\",\"4\":\"0.07049954\",\"5\":\"15.361503\",\"6\":\"1.353036e-16\",\"7\":\"0.9000510\",\"8\":\"0.8939935\",\"9\":\"36\"},{\"1\":\"South America\",\"2\":\"log_weight_sum\",\"3\":\"52.3002142\",\"4\":\"5.71317292\",\"5\":\"9.154320\",\"6\":\"1.410277e-10\",\"7\":\"0.9000510\",\"8\":\"0.8939935\",\"9\":\"36\"}],\"options\":{\"columns\":{\"min\":{},\"max\":[10]},\"rows\":{\"min\":[10],\"max\":[10]},\"pages\":{}}}\n  </script>\n</div>\n`````\n:::\n:::\n\n::: {.cell}\n\n```{.r .cell-code}\ndatatable(\n  regional_models %>%\n    arrange(continent, term),\n  options = list(pageLength = 25)\n)\n```\n\n::: {.cell-output-display}\n\n```{=html}\n<div class=\"datatables html-widget html-fill-item\" id